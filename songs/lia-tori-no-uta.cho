[Bm]{r:ko}こ{/r}{r:no}の{/r}{r:oka}丘{/r}[Gmaj7]{r:wo}を{/r}{r:koe}越え{/r}{r:ta}た{/r}[A]{r:a}あ{/r}{r:no}の{/r}{r:hi}日{/r}{r:ka}か{/r}{r:ra}ら{/r}{r:hen}変{/r}[Badd9]{r:wa}わ{/r}{r:ra}ら{/r}[Bm]{r:zu}ず{/r} {r:i}い{/r}[Badd9]{r:tsu}つ{/r}{r:ma}ま{/r}[Bm]{r:de}で{/r}{r:mo}も{/r}
[Gmaj7]{r:ma}ま{/r}{r:tt}っ{/r}{r:su}す{/r}{r:gu}ぐ{/r}{r:ni}に{/r}[A]{r:boku}僕{/r}{r:ta}た{/r}{r:chi}ち{/r}{r:ha}は{/r}{r:a}あ{/r}[Badd9]{r:ru}る{/r}{r:yo}よ{/r}{r:u}う{/r}[Bm]{r:ni}に{/r}[Badd9]
[Bm]{r:wa}わ{/r}{r:ta}た{/r}{r:tsu}つ{/r}{r:mi}み{/r}[Gmaj7]{r:no}の{/r}{r:yo}よ{/r}{r:u}う{/r}{r:na}な{/r}[A]{r:tsuyo}強{/r}{r:sa}さ{/r}{r:wo}を{/r}{r:mori}守{/r}[Badd9]{r:re}れ{/r}{r:ru}る{/r}[Bm]{r:yo}よ{/r} {r:ki}き{/r}[Badd9]{r:}っ{/r}[Bm]{r:to}と{/r}
